    {
      "id": "code_normalize_name",
      "prompt": "Implement normalize_name in formatter.py so it trims, lowercases, and converts spaces to hyphens. Run the fixture tests.",
      "fixture_repo": "fixtures/code_formatter",
      "allowed_tools": ["read_file", "patch_file", "run_shell"],
