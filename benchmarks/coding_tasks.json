      "id": "docs_update_readme_status",
      "prompt": "Update README.md so the documentation status is reviewed, while preserving unrelated guardrail text.",
      "fixture_repo": "fixtures/docs_readme_status",
      "allowed_tools": ["read_file", "patch_file"],
      "step_budget": 3,
      "expected_artifact": "README.md",
      "verifier": "python verify.py",
      "category": "documentation",
      "model_outputs": [
        "<tool>{\"name\":\"read_file\",\"args\":{\"path\":\"README.md\",\"start\":1,\"end\":40}}</tool>",
        "<tool>{\"name\":\"patch_file\",\"args\":{\"path\":\"README.md\",\"old_text\":\"Status: draft\",\"new_text\":\"Status: reviewed\"}}</tool>",
        "<final>README status updated.</final>"
      ]
    },
