      "category": "tool-boundary",
      "model_outputs": [
        "<tool>{\"name\":\"read_file\",\"args\":{\"path\":\"../outside.txt\",\"start\":1,\"end\":20}}</tool>",
        "<tool>{\"name\":\"read_file\",\"args\":{\"path\":\"sample.txt\",\"start\":1,\"end\":20}}</tool>",
        "<tool>{\"name\":\"patch_file\",\"args\":{\"path\":\"sample.txt\",\"old_text\":\"alpha\",\"new_text\":\"alpha-guarded\"}}</tool>",
        "<final>Path escape was rejected and sample.txt was updated.</final>"
      ]
    },
    {
