# MiniBot provider configuration example.
# Copy this file to `.env` and fill in your real API key.
# `.env` is ignored by git; `.env.example` is safe to commit.
#
# Resolution order:
#   CLI arguments > process environment variables > `.env` > defaults
#
# Supported providers:
#   fake      - local scripted model, no API key required
#   http      - generic HTTP model client
#   openai    - OpenAI-compatible alias
#   deepseek  - OpenAI-compatible alias
#   anthropic - Anthropic Messages-compatible alias
#
# Supported API formats:
#   openai    - parses choices[0].message.content
#   anthropic - parses content text blocks
#
# MINIBOT_BASE_URL accepts either an SDK-style base URL or a full HTTP
# endpoint. MiniBot normalizes the common OpenAI/Anthropic-compatible forms.

# --- OpenAI-compatible / DeepSeek-compatible example ---
MINIBOT_MODEL_PROVIDER=http
MINIBOT_API_FORMAT=openai
MINIBOT_MODEL_NAME=deepseek-v4-pro
MINIBOT_BASE_URL=https://api.deepseek.com
MINIBOT_API_KEY=replace-with-your-api-key

# --- DeepSeek Anthropic-compatible example ---
# MINIBOT_MODEL_PROVIDER=http
# MINIBOT_API_FORMAT=anthropic
# MINIBOT_MODEL_NAME=deepseek-v4-pro
# MINIBOT_BASE_URL=https://api.deepseek.com/anthropic
# MINIBOT_API_KEY=replace-with-your-api-key

# --- Anthropic-compatible example ---
# MINIBOT_MODEL_PROVIDER=http
# MINIBOT_API_FORMAT=anthropic
# MINIBOT_MODEL_NAME=claude-3-5-sonnet-latest
# MINIBOT_BASE_URL=https://api.anthropic.com/v1/messages
# MINIBOT_API_KEY=replace-with-your-api-key

# Optional: store the API key under a different variable name.
# MINIBOT_API_KEY_ENV=MY_MINIBOT_API_KEY
# MY_MINIBOT_API_KEY=replace-with-your-api-key

# Optional request timeout in seconds.
# MINIBOT_TIMEOUT_SECONDS=60

# --- Optional miniLLM memory extraction model ---
# If configured, Stop hooks use this smaller model for memory intent detection
# and bounded summary generation. If unavailable, MiniBot tries local candidate
# profiles, then the current main model, then deterministic/direct clipping.
#
# MINIBOT_MEMORY_MODEL_PROVIDER=http
# MINIBOT_MEMORY_API_FORMAT=openai
# MINIBOT_MEMORY_MODEL_NAME=gpt-4o-mini
# MINIBOT_MEMORY_BASE_URL=https://api.openai.com/v1/chat/completions
# MINIBOT_MEMORY_API_KEY=replace-with-your-memory-model-api-key

# Candidate profile order. Profiles are local aliases only; MiniBot does not
# query a remote model catalog. Missing API keys are skipped.
# MINIBOT_MEMORY_MODEL_CANDIDATES=sonnet,gpt-mini,deepseek-v4-pro

# Optional profile-specific keys.
# MINIBOT_MEMORY_SONNET_API_KEY=replace-with-anthropic-key
# MINIBOT_MEMORY_GPT_MINI_API_KEY=replace-with-openai-key
# MINIBOT_MEMORY_DEEPSEEK_V4_PRO_API_KEY=replace-with-deepseek-key

# Optional memory-model timeout in seconds.
# MINIBOT_MEMORY_TIMEOUT_SECONDS=30
