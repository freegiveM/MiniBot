# MiniBot provider configuration example.
# Copy this file to `.env` and fill in your real API key.
# `.env` is ignored by git; `.env.example` is safe to commit.
#
# Resolution order:
#   CLI arguments > process environment variables > `.env` > defaults
#
# Supported providers:
#   fake      - local scripted model, no API key required
#   http      - generic HTTP model client
#   openai    - OpenAI-compatible alias
#   deepseek  - OpenAI-compatible alias
#   anthropic - Anthropic Messages-compatible alias
#
# Supported API formats:
#   openai    - parses choices[0].message.content
#   anthropic - parses content text blocks

# --- OpenAI-compatible / DeepSeek-compatible example ---
MINIBOT_MODEL_PROVIDER=http
MINIBOT_API_FORMAT=openai
MINIBOT_MODEL_NAME=deepseek-v4-pro
MINIBOT_BASE_URL=https://api.deepseek.com/v1/chat/completions
MINIBOT_API_KEY=replace-with-your-api-key

# --- Anthropic-compatible example ---
# MINIBOT_MODEL_PROVIDER=http
# MINIBOT_API_FORMAT=anthropic
# MINIBOT_MODEL_NAME=claude-3-5-sonnet-latest
# MINIBOT_BASE_URL=https://api.anthropic.com/v1/messages
# MINIBOT_API_KEY=replace-with-your-api-key

# Optional: store the API key under a different variable name.
# MINIBOT_API_KEY_ENV=MY_MINIBOT_API_KEY
# MY_MINIBOT_API_KEY=replace-with-your-api-key

# Optional request timeout in seconds.
# MINIBOT_TIMEOUT_SECONDS=60
